---
import Layout from '../../layouts/Layout.astro';
import audits from '../../data/daily_audits.json';
import { marked } from 'marked';

export function getStaticPaths() {
  return audits.map(audit => ({
    params: { id: audit.bill_id.toLowerCase() },
    props: { audit },
  }));
}

const { audit } = Astro.props;

// Convert markdown to HTML for the blog post content
const blogPostHtml = marked.parse(audit.blog_post_markdown || '');

const formatMoney = (amount) => {
	if (amount >= 1_000_000_000) return `$${(amount / 1_000_000_000).toFixed(1)}B`;
	if (amount >= 1_000_000) return `$${(amount / 1_000_000).toFixed(1)}M`;
	return `$${amount.toLocaleString()}`;
};

const getYoutubeVideoId = (url) => {
    if (!url) return null;
    const match = url.match(/[?&]v=([^&]+)/);
    return match ? match[1] : null;
};
const videoId = getYoutubeVideoId(audit.youtube_url);
---

<Layout title={`Bill Dossier: ${audit.bill_id}`} activePath="/bill">
	<!-- Left Side: Analysis -->
    <section class="w-full lg:w-3/5 overflow-y-auto p-6 md:p-10 space-y-12">
        <!-- Breadcrumbs -->
        <nav class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-slate-500">
            <a class="hover:text-accent-gold" href="/">Intelligence Dashboard</a>
            <span class="material-symbols-outlined text-[10px] mx-2">chevron_right</span>
            <span class="text-accent-gold">{audit.bill_id}</span>
        </nav>
        
        <!-- Title Section -->
        <div class="space-y-4">
            <h1 class="font-header text-4xl md:text-5xl font-black uppercase leading-none tracking-tight text-white">
                {audit.youtube_metadata?.title || audit.bill_id}
            </h1>
            <div class="flex flex-wrap items-center gap-4 pt-2">
                <span class="px-2 py-1 bg-primary text-slate-300 text-[10px] font-black uppercase tracking-widest border border-slate-700">Classified: Grade A</span>
                {audit.fluff_detected ? (
                    <span class="px-2 py-1 bg-alert-red/20 text-alert-red text-[10px] font-black uppercase tracking-widest border border-alert-red/50">Status: Pork Detected</span>
                ) : (
                    <span class="px-2 py-1 bg-green-900/30 text-green-400 text-[10px] font-black uppercase tracking-widest border border-green-800">Status: Clean Bill</span>
                )}
                <span class="text-slate-500 text-[10px] font-bold uppercase tracking-widest">Proposed: {audit.date_proposed}</span>
            </div>
        </div>
        
        <!-- Thumbnail Section -->
        {audit.youtube_metadata?.thumbnail_url && (
            <div class="w-full rounded-xl overflow-hidden border border-slate-800 shadow-2xl relative">
                {audit.fluff_detected && (
                    <div class="absolute top-4 right-4 z-10 bg-alert-red text-white text-[10px] font-black px-4 py-1 uppercase tracking-widest shadow-[0_0_15px_rgba(239,68,68,0.5)]">
                        PORK ALERT
                    </div>
                )}
                <img src={audit.youtube_metadata.thumbnail_url} alt={`Thumbnail for ${audit.bill_id}`} class="w-full h-auto object-cover aspect-video" />
            </div>
        )}

        <!-- The Blog Post Content -->
        <div class="prose prose-invert prose-lg max-w-none prose-headings:font-header prose-headings:font-black prose-headings:uppercase prose-headings:tracking-widest prose-h2:text-accent-gold prose-h3:text-slate-300 prose-p:text-slate-400 prose-p:leading-relaxed prose-li:text-slate-400">
            {videoId && (
                <div class="mb-10 aspect-video w-full rounded-xl overflow-hidden border border-slate-800 shadow-2xl relative border-primary/50">
                    <iframe 
                        width="100%" 
                        height="100%" 
                        src={`https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1`} 
                        title="YouTube video player" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                        allowfullscreen 
                        class="absolute inset-0 w-full h-full"
                    ></iframe>
                </div>
            )}
            <div set:html={blogPostHtml} />
        </div>
        
        <!-- The Pork Report (Structured) -->
        {audit.fluff_detected && (
            <div class="pork-glow rounded-lg bg-alert-red/5 p-6 space-y-4 overflow-hidden relative mt-12">
                <div class="absolute top-0 right-0">
                    <div class="bg-alert-red text-white text-[10px] font-black px-4 py-1 uppercase tracking-widest rotate-0 md:rotate-12 translate-x-2 -translate-y-1 shadow-[0_0_15px_rgba(239,68,68,0.5)]">
                        PORK DETECTED
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-alert-red">report_problem</span>
                    <h3 class="font-header text-sm font-black uppercase tracking-widest text-alert-red">The Pork Report</h3>
                </div>
                <ul class="space-y-4">
                    {audit.fluff_items.map((item, index) => (
                        <li class="flex flex-col gap-1 border-b border-alert-red/20 pb-3 last:border-0 last:pb-0">
                            <span class="text-sm font-bold text-slate-200">"{item}"</span>
                        </li>
                    ))}
                </ul>
                <div class="mt-4 pt-4 border-t border-alert-red/20 flex justify-between items-center">
                    <span class="text-[10px] text-alert-red font-bold uppercase tracking-widest">Total Pork Value</span>
                    <span class="text-xl font-black text-alert-red">{formatMoney(audit.pork_barrel_spending)}</span>
                </div>
            </div>
        )}
        
        <!-- Sponsor Accountability -->
        {audit.sponsor_contact_info && (
            <div class="space-y-6 pb-20 mt-12">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-accent-gold">person</span>
                    <h3 class="font-header text-sm font-black uppercase tracking-widest text-white">Lead Sponsor Dossier</h3>
                </div>
                <div class="flex flex-col md:flex-row gap-6 p-6 bg-primary/20 border border-slate-800 rounded-lg">
                    <div class="flex-1 space-y-4">
                        <div>
                            <h4 class="text-xl font-bold text-white uppercase font-header">{audit.sponsor_contact_info.sponsor_name}</h4>
                            <p class="text-xs text-accent-gold font-bold uppercase tracking-widest">Sponsor</p>
                        </div>
                        <div class="flex flex-wrap gap-4">
                            <a class="px-4 py-2 bg-background-dark border border-slate-700 rounded hover:border-accent-gold hover:text-accent-gold transition-colors text-slate-300 font-bold uppercase tracking-widest text-[10px] flex items-center gap-2" href={`tel:${audit.sponsor_contact_info.phone_number.replace(/[^0-9]/g, '')}`}>
                                <span class="material-symbols-outlined text-sm">call</span> {audit.sponsor_contact_info.phone_number}
                            </a>
                            <a class="px-4 py-2 bg-background-dark border border-slate-700 rounded hover:border-accent-gold hover:text-accent-gold transition-colors text-slate-300 font-bold uppercase tracking-widest text-[10px] flex items-center gap-2" href={audit.sponsor_contact_info.website} target="_blank">
                                <span class="material-symbols-outlined text-sm">language</span> Official Website
                            </a>
                            {audit.sponsor_contact_info.social_handles?.twitter && (
                                <a class="px-4 py-2 bg-background-dark border border-slate-700 rounded hover:border-accent-gold hover:text-accent-gold transition-colors text-slate-300 font-bold uppercase tracking-widest text-[10px] flex items-center gap-2" href={`https://twitter.com/${audit.sponsor_contact_info.social_handles.twitter}`} target="_blank">
                                    <span class="material-symbols-outlined text-sm">share</span> @{audit.sponsor_contact_info.social_handles.twitter}
                                </a>
                            )}
                        </div>
                    </div>
                </div>
            </div>
        )}
    </section>
    
    <!-- Right Side: Source Text Context -->
    <aside class="hidden lg:flex w-2/5 flex-col bg-background-dark border-l border-primary/50 p-6 relative">
        <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-slate-500">article</span>
                <h3 class="font-header text-[10px] font-black uppercase tracking-[0.2em] text-slate-500">Bill Context</h3>
            </div>
        </div>
        
        <!-- Stylized Context Container -->
        <div class="flex-1 glass-panel rounded-lg overflow-y-auto p-8 font-serif text-slate-300 text-sm leading-loose shadow-2xl relative">
            <div class="absolute inset-0 pointer-events-none opacity-5 flex items-center justify-center">
                <div class="text-6xl font-black rotate-45 border-8 border-slate-100 p-8">UNCLASSIFIED</div>
            </div>
            
            <div class="max-w-prose mx-auto space-y-8 relative z-10">
                <div class="text-center border-b border-slate-700 pb-8 space-y-2">
                    <p class="font-bold text-lg">CONGRESSIONAL RECORD</p>
                    <p class="font-black text-2xl tracking-tighter">{audit.bill_id}</p>
                </div>
                
                <p class="font-bold uppercase text-center text-xs tracking-widest text-accent-gold">Historical Context</p>
                <p class="italic text-center text-slate-400 bg-black/20 p-4 rounded border border-slate-800">
                    {audit.historical_context}
                </p>
                
                <div class="space-y-6 mt-8">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="p-4 bg-primary/10 border border-slate-800 rounded text-center">
                            <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Total Request</p>
                            <p class="text-xl font-bold text-white">{formatMoney(audit.total_spending)}</p>
                        </div>
                        <div class="p-4 bg-primary/10 border border-slate-800 rounded text-center">
                            <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Legitimate</p>
                            <p class="text-xl font-bold text-green-400">{formatMoney(audit.legitimate_spending)}</p>
                        </div>
                    </div>
                    
                    {audit.fluff_detected && (
                        <div class="p-4 bg-alert-red/10 border border-alert-red/30 rounded text-center mt-4">
                            <p class="text-[10px] text-alert-red font-bold uppercase tracking-widest mb-1">Pork Ratio</p>
                            <p class="text-3xl font-black text-alert-red">{audit.pork_to_value_ratio}%</p>
                            <p class="text-xs text-alert-red/70 mt-2 font-mono">WARNING: High variance detected</p>
                        </div>
                    )}
                </div>
            </div>
        </div>
        
        <!-- Footer/Scanline effect -->
        <div class="mt-4 flex items-center justify-between text-[10px] font-mono text-slate-600">
            <span>DOC_ID: {audit.bill_id}_FINAL</span>
            <span>DATE: {audit.date_proposed}</span>
        </div>
    </aside>
</Layout>
