---
import Layout from '../layouts/Layout.astro';
import audits from '../data/daily_audits.json';

// Calculate live metrics
const totalSpending = audits.reduce((sum, audit) => sum + (audit.total_spending || 0), 0);
const porkAlerts = audits.filter(audit => audit.fluff_detected).length;

const formatMoney = (amount) => {
	if (amount >= 1_000_000_000) return `$${(amount / 1_000_000_000).toFixed(1)}B`;
	if (amount >= 1_000_000) return `$${(amount / 1_000_000).toFixed(1)}M`;
	return `$${amount.toLocaleString()}`;
};

// Use audits directly for the latest briefs list, but only show those that have been mapped by the crawler
const latestAudits = audits.filter(audit => audit.youtube_url);
---

<Layout title="Intelligence Dashboard" activePath="/">
	<div class="flex-1 flex flex-col lg:flex-row max-w-[1600px] mx-auto w-full p-6 lg:p-10 gap-10 overflow-y-auto custom-scrollbar pb-24 lg:pb-10">
		<!-- Main Content Area -->
		<div class="flex-1 flex flex-col gap-10">
			<!-- Bento Grid Metrics -->
			<section class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div class="bg-primary/20 border border-slate-800 p-8 rounded-xl relative overflow-hidden group">
					<div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
						<span class="material-symbols-outlined text-8xl">payments</span>
					</div>
					<h3 class="text-slate-400 text-sm font-bold uppercase tracking-wider mb-4">Total Proposed Spending Today</h3>
					<div class="flex items-end gap-4">
						<span class="text-5xl font-bold text-white tracking-tighter">{formatMoney(totalSpending)}</span>
						<span class="text-emerald-500 font-bold mb-1 flex items-center">
							<span class="material-symbols-outlined text-sm">trending_up</span>
							Live
						</span>
					</div>
					<p class="text-slate-500 text-xs mt-4 italic">Aggregated from daily Congressional filings</p>
				</div>
				<div class="bg-primary/20 border border-slate-800 p-8 rounded-xl relative overflow-hidden group">
					<div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
						<span class="material-symbols-outlined text-8xl">error</span>
					</div>
					<h3 class="text-slate-400 text-sm font-bold uppercase tracking-wider mb-4">Active Pork Alerts</h3>
					<div class="flex items-end gap-4">
						<span class="text-5xl font-bold text-white tracking-tighter">{porkAlerts}</span>
						<span class="bg-red-500/20 text-red-500 border border-red-500/50 px-2 py-0.5 rounded text-[10px] font-bold uppercase mb-2 tracking-widest">Critical Priority</span>
					</div>
					<p class="text-slate-500 text-xs mt-4 italic">Anomalous spending patterns detected in {porkAlerts} active bills</p>
				</div>
			</section>

			<!-- Latest Bill Briefs -->
			<section>
				<div class="flex items-center justify-between mb-8 border-b border-slate-800 pb-4">
					<h2 class="text-2xl font-bold text-white flex items-center gap-3 italic uppercase tracking-tighter">
						<span class="w-2 h-8 bg-accent-gold"></span>
						Latest Bill Briefs
					</h2>
					<a class="text-accent-gold text-xs font-bold uppercase tracking-widest hover:underline flex items-center gap-1" href="/archive">
						Archives <span class="material-symbols-outlined text-sm">arrow_forward</span>
					</a>
				</div>
				<div class="grid grid-cols-1 gap-6">
					{latestAudits.map((audit) => (
						<div class="group bg-primary/10 border border-slate-800 rounded-xl overflow-hidden flex flex-col md:flex-row shadow-lg">
							<div class="w-full md:w-1/3 min-h-[200px] border-r border-slate-800 relative bg-primary/50 flex flex-col justify-between p-6 overflow-hidden group-hover:bg-primary transition-colors">
								{audit.youtube_metadata?.thumbnail_url && (
									<img src={audit.youtube_metadata.thumbnail_url} alt="" class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover:opacity-40 transition-opacity mix-blend-luminosity grayscale group-hover:grayscale-0" />
								)}
								<div class="absolute inset-0 opacity-10 blur-sm pointer-events-none" style="background: radial-gradient(circle at center, #EAB308 0%, transparent 70%);"></div>
								<div class="relative z-10">
									<span class="bg-red-500/20 text-red-500 border border-red-500/50 px-2 py-1 rounded text-[10px] font-black uppercase tracking-widest mb-4 inline-block shadow-[0_0_15px_rgba(239,68,68,0.2)]">Pork Alert</span>
									<h3 class="text-2xl font-black text-white italic tracking-tighter mb-1 mt-6">{audit.bill_id}</h3>
									<p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6">{audit.sponsor_contact_info.sponsor_name}</p>
								</div>
								<div class="relative z-10 flex gap-4 mt-auto">
									<div class="flex flex-col">
										<span class="text-[9px] text-slate-500 uppercase font-bold tracking-widest">Total Request</span>
										<span class="text-lg font-bold text-slate-300">{formatMoney(audit.total_spending)}</span>
									</div>
									<div class="flex flex-col border-l border-slate-700 pl-4">
										<span class="text-[9px] text-red-400 uppercase font-bold tracking-widest">Pork Value</span>
										<span class="text-lg font-bold text-red-500">{formatMoney(audit.pork_barrel_spending)}</span>
									</div>
								</div>
							</div>
							
							<div class="w-full md:w-2/3 p-6 flex flex-col justify-center bg-background-dark/50">
								<div class="mb-6 space-y-4">
									<div>
										<h4 class="text-xs font-bold text-green-400 uppercase tracking-wider mb-2">The Goods (Stated Purpose)</h4>
										<p class="text-slate-300 text-sm border-l-2 border-green-500/50 pl-4 py-1 italic leading-relaxed">{audit.historical_context}</p>
									</div>
									
									<div>
										<h4 class="text-xs font-bold text-accent-gold uppercase tracking-wider mb-2">The Fluff (Audit Findings)</h4>
										<div class="space-y-2">
											{audit.fluff_items.map(item => (
												<p class="text-slate-300 text-sm border-l-2 border-red-500/50 pl-4 py-1 italic leading-relaxed">"{item}"</p>
											))}
										</div>
									</div>
								</div>
								<div class="flex items-center gap-4 pt-4 border-t border-slate-800 text-xs mt-auto">
									<a href={`/bill/${audit.bill_id.toLowerCase()}`} class="px-4 py-2 bg-accent-gold text-primary hover:bg-yellow-400 font-black uppercase tracking-widest rounded transition-colors flex items-center gap-2">
										<span class="material-symbols-outlined text-sm">visibility</span> Read More
									</a>
								</div>
							</div>
						</div>
					))}
				</div>
			</section>
		</div>

		<!-- Sidebar -->
		<aside class="w-full lg:w-80 flex flex-col gap-10">
			<!-- Industry Winners List -->
			<div class="bg-primary/10 border border-slate-800 p-6 rounded-xl">
				<h3 class="text-white text-xs font-black uppercase tracking-[0.2em] mb-6 flex items-center gap-2">
					<span class="material-symbols-outlined text-accent-gold text-lg">monitoring</span>
					Industry Winners
				</h3>
				<div class="space-y-4">
					<div class="border-l-2 border-accent-gold pl-4">
						<p class="text-xs text-slate-500 font-bold uppercase">Energy Sector</p>
						<p class="text-lg font-bold text-white">+$1.2B</p>
						<p class="text-[10px] text-emerald-500 font-bold uppercase">+12% Surplus</p>
					</div>
					<div class="border-l-2 border-accent-gold pl-4">
						<p class="text-xs text-slate-500 font-bold uppercase">Defense Tech</p>
						<p class="text-lg font-bold text-white">+$840M</p>
						<p class="text-[10px] text-emerald-500 font-bold uppercase">+8.4% Variance</p>
					</div>
					<div class="border-l-2 border-accent-gold pl-4">
						<p class="text-xs text-slate-500 font-bold uppercase">Pharma Corp</p>
						<p class="text-lg font-bold text-white">+$2.1B</p>
						<p class="text-[10px] text-emerald-500 font-bold uppercase">+15.2% Profitability</p>
					</div>
					<div class="border-l-2 border-accent-gold pl-4">
						<p class="text-xs text-slate-500 font-bold uppercase">Cyber Security</p>
						<p class="text-lg font-bold text-white">+$560M</p>
						<p class="text-[10px] text-emerald-500 font-bold uppercase">+5.0% Growth</p>
					</div>
				</div>
			</div>

			<!-- Newsletter Signup -->
			<div class="bg-accent-gold p-6 rounded-xl text-primary">
				<h3 class="text-sm font-black uppercase tracking-widest mb-2 flex items-center gap-2">
					<span class="material-symbols-outlined">mail</span>
					Money Trail
				</h3>
				<p class="text-xs font-bold leading-tight mb-4">Subscribe to receive classified spending alerts and investigative leaks directly.</p>
				<div class="space-y-2">
					<input class="w-full bg-white/20 border-primary/20 rounded-lg text-xs placeholder:text-primary/70 border-none focus:ring-1 focus:ring-primary px-3 py-2" placeholder="agent@brief.gov" type="email"/>
					<button class="w-full bg-primary text-white text-[10px] font-black uppercase tracking-[0.2em] py-3 rounded-lg hover:bg-primary/90 transition-colors">
						Initialize Briefing
					</button>
				</div>
			</div>

			<!-- Status Indicators -->
			<div class="bg-background-dark border border-slate-800 p-4 rounded-xl">
				<div class="flex items-center justify-between text-[10px] font-bold text-slate-500 uppercase tracking-tighter mb-2">
					<span>Connection Status</span>
					<span class="text-emerald-500 flex items-center gap-1">
						<span class="size-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
						Encrypted
					</span>
				</div>
				<div class="flex items-center justify-between text-[10px] font-bold text-slate-500 uppercase tracking-tighter">
					<span>Database Sync</span>
					<span class="text-white">Live Feed</span>
				</div>
			</div>
		</aside>
	</div>
</Layout>
